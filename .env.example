# Copy to `.env` and adjust. Only MAP_STYLE_URL matters for v1.

# Basemap style for MapLibre GL JS. Single config point (SPEC §1/§7) so the
# basemap can be swapped for a self-hosted vector style later without code
# changes. Used starting in slice 2 (the map island).
#
# Default for local dev is the free MapLibre demo style. Replace with a free
# outdoor/topo style (some providers need a key appended) when you want nicer
# tiles. No API key is required for rendering with the demo style.
MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
