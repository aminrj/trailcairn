# Dependencies & build output
node_modules/
dist/
.astro/

# Generated responsive image derivatives (rebuilt from originals on build)
public/_gen/

# Generated photo manifest — committed per *published* hike via `git add -f`
# (it's the R2 metadata bridge). Ignored by default so the bundled example and
# unpublished hikes don't churn.
photos.manifest.json
.env
.env.*
!.env.example

# Raw Google Takeout / staging area for un-curated data
test-data/
takeout/

# Personal hike data — ignore ALL real hikes by default,
# but keep the bundled example and template committed.
src/content/hikes/*/
!src/content/hikes/_example/
!src/content/hikes/_TEMPLATE/

# OS noise
.DS_Store
Thumbs.db

# Tooling artifacts
.playwright-mcp/
