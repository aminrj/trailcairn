---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Map from '../../components/Map.astro';
import type { MapPhoto } from '../../components/Map.astro';
import StatsBand from '../../components/StatsBand.astro';
import ElevationProfile from '../../components/ElevationProfile.astro';
import Gallery from '../../components/Gallery.astro';
import Replay from '../../components/Replay.astro';
import { getVisibleHikes, hikeDir, loadGpx, resolveStats } from '../../lib/hikes';
import { GpxError, normalizedTimeline } from '../../lib/gpx';
import { processHikePhotos } from '../../lib/photos';
import { resolveHikeTimeZone, formatClock } from '../../lib/timezone';
import type { TimeStats } from '../../lib/stats';

export async function getStaticPaths() {
  const hikes = await getVisibleHikes();
  return hikes.map((hike) => ({ params: { slug: hike.id }, props: { hike } }));
}

const { hike } = Astro.props;
const { Content } = await render(hike);

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'long' });

// Derive from the GPX at build time; frontmatter overrides win (SPEC §2.1).
let gpx = null;
let gpxErrorMessage: string | null = null;
try {
  gpx = loadGpx(hike);
} catch (err) {
  if (err instanceof GpxError) gpxErrorMessage = err.message;
  else throw err;
}
const stats = gpx
  ? resolveStats(hike, gpx.stats)
  : {
      distance_km: hike.data.distance_km ?? null,
      ascent_m: hike.data.ascent_m ?? null,
      descent_m: hike.data.descent_m ?? null,
      duration: hike.data.duration ?? null,
    };

// Resolve the hike's timezone (start coords → IANA zone, frontmatter override,
// default) and build local time-of-day stats when the GPX has timestamps.
const tz = resolveHikeTimeZone({
  lat: gpx?.start[1],
  lng: gpx?.start[0],
  frontmatterTz: hike.data.timezone,
});
let timeStats: TimeStats | null = null;
if (gpx?.stats.startEpochMs != null && gpx.stats.endEpochMs != null && gpx.stats.movingSeconds != null) {
  timeStats = {
    startClock: formatClock(gpx.stats.startEpochMs, tz.id),
    endClock: formatClock(gpx.stats.endEpochMs, tz.id),
    movingSeconds: gpx.stats.movingSeconds,
    wallClockSeconds: gpx.stats.durationSeconds!,
    paceSecPerKm: gpx.stats.movingPaceSecPerKm,
    tzId: tz.id,
    days: gpx.stats.days ?? 1,
    nights: gpx.stats.nights,
  };
}

// Photos: EXIF/timestamp placement + derivatives (slice 4). The hike's timezone
// is shared so EXIF local-without-zone timestamps resolve to UTC consistently.
const { photos, cover } = await processHikePhotos(
  { slug: hike.id, dir: hikeDir(hike), cover: hike.data.cover, timezone: tz.id },
  gpx,
);
const mapPhotos: MapPhoto[] = photos
  .map((p, index) => ({ p, index }))
  .filter(({ p }) => p.placed)
  .map(({ p, index }) => ({
    lng: p.lng!,
    lat: p.lat!,
    thumb: p.derivatives.thumb,
    full: p.derivatives.full,
    caption: p.caption ?? undefined,
    index,
  }));
---

<BaseLayout title={hike.data.title} description={hike.data.summary} ogImage={`/og/${hike.id}.png`}>
  <article data-pagefind-body>
    <header class="hike-header">
      <h1>{hike.data.title}</h1>
      <p class="prose" data-pagefind-meta="summary">{hike.data.summary}</p>
      <span hidden data-pagefind-meta="location">{hike.data.location}</span>
      {hike.data.tags.map((t) => <span hidden data-pagefind-filter="tag">{t}</span>)}
    </header>

    {
      gpx ? (
        <Map
          id={`map-${hike.id}`}
          lines={[gpx.line]}
          starts={hike.data.hidePrecisePins ? [null] : [gpx.start]}
          bounds={gpx.bounds}
          photos={mapPhotos}
          reveal={true}
          height="55vh"
        />
      ) : (
        <p class="placeholder-note">Could not render the track: {gpxErrorMessage}</p>
      )
    }

    <StatsBand
      date={dateFmt.format(hike.data.date)}
      location={hike.data.location}
      distance_km={stats.distance_km}
      ascent_m={stats.ascent_m}
      descent_m={stats.descent_m}
      duration={stats.duration}
      timeStats={timeStats}
    />

    {gpx && <ElevationProfile elevations={gpx.elevations} cumulativeKm={gpx.cumulativeKm} />}

    {
      gpx && gpx.coordinates.length > 1 && (
        <Replay
          mapId={`map-${hike.id}`}
          coordinates={gpx.coordinates}
          timeline={normalizedTimeline(gpx)}
          cumulativeKm={gpx.cumulativeKm}
          totalKm={gpx.cumulativeKm[gpx.cumulativeKm.length - 1]}
          durationSeconds={gpx.stats.durationSeconds}
        />
      )
    }

    <div class="prose hike-body">
      <Content />
    </div>

    <Gallery photos={photos} coverFilename={cover?.filename} />
    {
      photos.some((p) => !p.placed) && (
        <p class="meta unplaced-note">
          Photos without a dot aren't on the map (no GPS or matching timestamp). Pin them via{' '}
          <code>photos/_photos.json</code>.
        </p>
      )
    }
  </article>
</BaseLayout>

<style>
  .hike-body {
    margin-top: 2rem;
  }
</style>
