---
import BaseLayout from '../layouts/BaseLayout.astro';
import Map from '../components/Map.astro';
import LifetimeBand from '../components/LifetimeBand.astro';
import Search from '../components/Search.astro';
import { SITE_TAGLINE } from '../consts';
import { getVisibleHikes, getIndexMapData } from '../lib/hikes';

const hikes = await getVisibleHikes();
const mapData = await getIndexMapData();

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
---

<BaseLayout>
  <section class="hike-header">
    <h1>{SITE_TAGLINE}</h1>
    <p class="prose">A public ledger of hikes. Every track sits on the lifetime map below.</p>
  </section>

  <LifetimeBand stats={mapData.lifetime} />

  {
    mapData.bounds && (
      <Map
        id="index-map"
        lines={mapData.lines}
        starts={mapData.starts}
        bounds={mapData.bounds}
        hikes={mapData.hikes}
        overview={true}
        defaultBasemap="pale"
        height="62vh"
      />
    )
  }

  <Search />

  {
    hikes.length === 0 ? (
      <p class="placeholder-note">
        No hikes yet. Copy <code>src/content/hikes/_TEMPLATE/</code> to a new folder to add one.
      </p>
    ) : (
      <ul class="hike-list">
        {hikes.map((hike) => (
          <li class="hike-card">
            <h2>
              <a href={`/hikes/${hike.id}`}>{hike.data.title}</a>{' '}
              {hike.data.status === 'draft' && <span class="draft-badge">draft</span>}
            </h2>
            <p class="meta">
              {dateFmt.format(hike.data.date)} · {hike.data.location}
            </p>
            <p>{hike.data.summary}</p>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
