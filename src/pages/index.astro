---
import BaseLayout from '../layouts/BaseLayout.astro';
import Map from '../components/Map.astro';
import LifetimeBand from '../components/LifetimeBand.astro';
import HikeSearch from '../components/HikeSearch.astro';
import RouteMotif from '../components/RouteMotif.astro';
import { SITE_TAGLINE } from '../consts';
import { getVisibleHikes, getIndexMapData, hikeDir, type IndexMapHike } from '../lib/hikes';
import { getHikeCover, type HikeCover } from '../lib/photos';

const hikes = await getVisibleHikes();
const mapData = await getIndexMapData();

// Per-hike extras for the magazine cards (stats line + route motif), keyed by
// slug. `Map` here is the component, so use a plain object.
const cardData: Record<string, IndexMapHike> = {};
for (const h of mapData.hikes) cardData[h.slug] = h;

const statLine = (h: IndexMapHike | undefined) =>
  [h?.distance_km != null ? `${h.distance_km} km` : null, h?.ascent_m != null ? `${h.ascent_m} m` : null, h?.duration ?? null]
    .filter(Boolean)
    .join('  ·  ');

// Cover thumbnail per hike for the logbook (only the cover is processed, not
// every photo — see getHikeCover). Plain object: `Map` here is the component.
const covers: Record<string, HikeCover | null> = {};
for (const hike of hikes) {
  covers[hike.id] = await getHikeCover({ slug: hike.id, dir: hikeDir(hike), cover: hike.data.cover });
}

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });

// Searchable text per hike for the live filter (title/location/tags/date/summary).
// Diacritics are folded (å→a) so "laxa" matches "Laxå".
const COMBINING = new RegExp('[\\u0300-\\u036f]', 'g');
const fold = (s: string) => s.normalize('NFD').replace(COMBINING, '').toLowerCase();
const searchText = (h: (typeof hikes)[number]) =>
  fold(
    [h.data.title, h.data.location, (h.data.tags ?? []).join(' '), dateFmt.format(h.data.date), h.data.summary].join(' '),
  );
---

<BaseLayout>
  <section class="home-hero">
    <h1>{SITE_TAGLINE}</h1>
    <p class="home-sub">A personal, public ledger of where I've wandered — every hike mapped.</p>
  </section>

  <LifetimeBand stats={mapData.lifetime} />

  {hikes.length > 0 && <HikeSearch />}

  {/* The overview map is the permanent centerpiece — always rendered, even with no hikes. */}
  <Map
    id="index-map"
    lines={mapData.lines}
    starts={mapData.starts}
    bounds={mapData.bounds}
    hikes={mapData.hikes}
    overview={true}
    defaultBasemap="pale"
    height="62vh"
  />

  {
    hikes.length === 0 ? (
      <p class="placeholder-note">
        No hikes yet. Copy <code>src/content/hikes/_TEMPLATE/</code> to a new folder to add one — it
        will appear on the map above.
      </p>
    ) : (
      <>
        <ul class="hike-list">
          {hikes.map((hike) => {
            const cover = covers[hike.id];
            const extra = cardData[hike.id];
            const stats = statLine(extra);
            return (
              <li class="hike-card" data-slug={hike.id} data-search={searchText(hike)}>
                <a class="hike-card-link" href={`/hikes/${hike.id}`}>
                  <span class="hike-card-cover">
                    {cover ? (
                      <img
                        src={cover.medium}
                        width={cover.width}
                        height={cover.height}
                        loading="lazy"
                        decoding="async"
                        alt=""
                        style={`background-image:url(${cover.blur});background-size:cover`}
                      />
                    ) : (
                      <span class="hike-card-cover--empty" aria-hidden="true" />
                    )}
                  </span>
                  <span class="hike-card-body">
                    <span class="hike-card-title">
                      {hike.data.title}
                      {hike.data.status === 'draft' && <span class="draft-badge">draft</span>}
                    </span>
                    {stats && <span class="hike-card-stats">{stats}</span>}
                    <span class="hike-card-meta">
                      {dateFmt.format(hike.data.date)}
                      <span class="hike-card-loc"> · {hike.data.location}</span>
                    </span>
                    <span class="hike-card-summary">{hike.data.summary}</span>
                  </span>
                  {extra && extra.coords.length > 1 && (
                    <RouteMotif lines={[extra.coords]} width={140} height={90} strokeWidth={2} class="hike-card-route" />
                  )}
                </a>
              </li>
            );
          })}
        </ul>
        <p class="placeholder-note" data-no-matches hidden>
          No hikes match your search — clear it to see them all on the map again.
        </p>
      </>
    )
  }
</BaseLayout>
