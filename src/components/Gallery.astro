---
import type { ProcessedPhoto } from '../lib/photos';

interface Props {
  photos: ProcessedPhoto[];
  /** Filename of the hero photo (the cover); defaults to the first photo. */
  coverFilename?: string | null;
}
const { photos, coverFilename } = Astro.props;

// Hero = the cover (or first); the rest flow in a varied masonry below it.
const heroIndex = Math.max(
  0,
  coverFilename ? photos.findIndex((p) => p.filename === coverFilename) : 0,
);
const hero = photos[heroIndex];
const rest = photos.map((p, i) => ({ p, i })).filter(({ i }) => i !== heroIndex);

// Data the lightbox script needs (full image, caption, coords for map fly-to).
const lightboxData = photos.map((p, i) => ({
  index: i,
  full: p.derivatives.full,
  caption: p.caption,
  placed: p.placed,
  lng: p.lng,
  lat: p.lat,
}));
---

{
  photos.length > 0 && (
    <section class="gallery" data-gallery>
      <script type="application/json" class="gallery-data" set:html={JSON.stringify(lightboxData)} />

      {hero && (
        <figure class="gallery-hero">
          <button class="gallery-item" data-index={heroIndex} aria-label={hero.caption ?? 'Cover photo'}>
            <img
              src={hero.derivatives.medium}
              srcset={`${hero.derivatives.medium} 1000w, ${hero.derivatives.full} 1800w`}
              sizes="(max-width: 760px) 100vw, 720px"
              width={hero.width}
              height={hero.height}
              decoding="async"
              alt={hero.caption ?? ''}
              style={`background-image:url(${hero.blur});background-size:cover`}
            />
            {hero.placed && <span class="pin-dot" title="Placed on the map" />}
          </button>
          {hero.caption && <figcaption>{hero.caption}</figcaption>}
        </figure>
      )}

      {rest.length > 0 && (
        <div class="gallery-masonry">
          {rest.map(({ p, i }) => (
            <figure class="gallery-cell">
              <button class="gallery-item" data-index={i} aria-label={p.caption ?? `Photo ${i + 1}`}>
                <img
                  src={p.derivatives.thumb}
                  srcset={`${p.derivatives.thumb} 320w, ${p.derivatives.medium} 1000w`}
                  sizes="(max-width: 600px) 45vw, 240px"
                  width={p.width}
                  height={p.height}
                  loading="lazy"
                  decoding="async"
                  alt={p.caption ?? ''}
                  style={`background-image:url(${p.blur});background-size:cover`}
                />
                {p.placed && <span class="pin-dot" title="Placed on the map" />}
              </button>
              {p.caption && <figcaption>{p.caption}</figcaption>}
            </figure>
          ))}
        </div>
      )}

      <div class="lightbox" data-lightbox hidden>
        <button class="lb-close" data-lb-close aria-label="Close">×</button>
        <button class="lb-prev" data-lb-prev aria-label="Previous">‹</button>
        <img class="lb-image" data-lb-image alt="" />
        <button class="lb-next" data-lb-next aria-label="Next">›</button>
        <p class="lb-caption" data-lb-caption />
      </div>
    </section>
  )
}

<style>
  .gallery {
    margin-top: 2.5rem;
  }
  /* Shared clickable photo button. */
  .gallery-item {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    line-height: 0;
  }
  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
    background-color: #e7e3da;
  }
  .gallery figure {
    margin: 0;
  }
  .gallery figcaption {
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: var(--ink-soft, #5b5b54);
    line-height: 1.4;
    margin-top: 0.45rem;
  }

  /* Hero — the cover photo, wide and large. */
  .gallery-hero {
    margin-bottom: 0.7rem;
  }
  .gallery-hero .gallery-item img {
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 10px;
  }
  .gallery-hero figcaption {
    margin-top: 0.55rem;
  }

  /* The rest — a varied masonry (natural aspect ratios), not rigid squares. */
  .gallery-masonry {
    columns: 3 220px;
    column-gap: 0.7rem;
  }
  .gallery-cell {
    break-inside: avoid;
    margin-bottom: 0.7rem;
  }

  .pin-dot {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #3f6b4d;
    border: 2px solid #fff;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(20, 20, 18, 0.92);
    display: grid;
    grid-template-columns: 4rem 1fr 4rem;
    grid-template-rows: 1fr auto;
    align-items: center;
    justify-items: center;
    padding: 1rem;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lb-image {
    grid-column: 2;
    grid-row: 1;
    max-width: 100%;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 4px;
  }
  .lb-caption {
    grid-column: 1 / -1;
    grid-row: 2;
    color: #f3f1ec;
    font-size: 0.9rem;
    margin: 0.75rem 0 0;
    text-align: center;
    min-height: 1.2em;
  }
  .lb-close,
  .lb-prev,
  .lb-next {
    background: none;
    border: 0;
    color: #fff;
    cursor: pointer;
    line-height: 1;
  }
  .lb-close {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    font-size: 2rem;
  }
  .lb-prev,
  .lb-next {
    font-size: 3rem;
    grid-row: 1;
    padding: 0 0.5rem;
  }
  .lb-prev {
    grid-column: 1;
  }
  .lb-next {
    grid-column: 3;
  }
</style>

<script>
  type LBPhoto = {
    index: number;
    full: string;
    caption: string | null;
    placed: boolean;
    lng: number | null;
    lat: number | null;
  };

  function initGallery(root: HTMLElement) {
    if (root.dataset.galleryReady) return;
    root.dataset.galleryReady = 'true';
    const dataEl = root.querySelector('.gallery-data');
    if (!dataEl?.textContent) return;
    const photos: LBPhoto[] = JSON.parse(dataEl.textContent);

    const lb = root.querySelector<HTMLElement>('[data-lightbox]')!;
    const img = root.querySelector<HTMLImageElement>('[data-lb-image]')!;
    const caption = root.querySelector<HTMLElement>('[data-lb-caption]')!;
    let current = 0;

    // Locate a map on the same page so opening a placed photo flies to it.
    const mapEl = document.querySelector<HTMLElement>('[data-map]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function show(i: number) {
      current = (i + photos.length) % photos.length;
      const p = photos[current];
      img.src = p.full;
      img.alt = p.caption ?? '';
      caption.textContent = p.caption ?? '';
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
      if (p.placed && p.lng != null && p.lat != null && mapEl && (mapEl as any).__map) {
        const map = (mapEl as any).__map;
        if (reducedMotion) map.jumpTo({ center: [p.lng, p.lat], zoom: 14 });
        else map.flyTo({ center: [p.lng, p.lat], zoom: 14, speed: 0.8 });
      }
    }
    function close() {
      lb.hidden = true;
      document.body.style.overflow = '';
    }

    root.querySelectorAll<HTMLElement>('.gallery-item').forEach((btn) => {
      btn.addEventListener('click', () => show(Number(btn.dataset.index)));
    });
    root.querySelector('[data-lb-close]')!.addEventListener('click', close);
    root.querySelector('[data-lb-prev]')!.addEventListener('click', () => show(current - 1));
    root.querySelector('[data-lb-next]')!.addEventListener('click', () => show(current + 1));
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(current - 1);
      else if (e.key === 'ArrowRight') show(current + 1);
    });

    // Clicking a photo marker on the map opens the matching lightbox entry.
    document.addEventListener('photo-marker-click', (e) => {
      const idx = (e as CustomEvent).detail?.index;
      if (typeof idx === 'number') show(idx);
    });
  }

  const init = () => document.querySelectorAll<HTMLElement>('[data-gallery]').forEach(initGallery);
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>
