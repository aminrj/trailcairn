---
import type { ProcessedPhoto } from '../lib/photos';

interface Props {
  photos: ProcessedPhoto[];
}
const { photos } = Astro.props;

// Data the lightbox script needs (full image, caption, coords for map fly-to).
const lightboxData = photos.map((p, i) => ({
  index: i,
  full: p.derivatives.full,
  caption: p.caption,
  placed: p.placed,
  lng: p.lng,
  lat: p.lat,
}));
---

{
  photos.length > 0 && (
    <section class="gallery" data-gallery>
      <script type="application/json" class="gallery-data" set:html={JSON.stringify(lightboxData)} />
      <ul class="gallery-grid">
        {photos.map((p, i) => (
          <li>
            <button class="gallery-item" data-index={i} aria-label={p.caption ?? `Photo ${i + 1}`}>
              <img
                src={p.derivatives.thumb}
                srcset={`${p.derivatives.thumb} 320w, ${p.derivatives.medium} 1000w`}
                sizes="(max-width: 600px) 45vw, 200px"
                width={p.width}
                height={p.height}
                loading="lazy"
                decoding="async"
                alt={p.caption ?? ''}
                style={`background-image:url(${p.blur});background-size:cover`}
              />
              {p.placed && <span class="pin-dot" title="Placed on the map" />}
            </button>
          </li>
        ))}
      </ul>

      <div class="lightbox" data-lightbox hidden>
        <button class="lb-close" data-lb-close aria-label="Close">×</button>
        <button class="lb-prev" data-lb-prev aria-label="Previous">‹</button>
        <img class="lb-image" data-lb-image alt="" />
        <button class="lb-next" data-lb-next aria-label="Next">›</button>
        <p class="lb-caption" data-lb-caption />
      </div>
    </section>
  )
}

<style>
  .gallery-grid {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.5rem;
  }
  .gallery-item {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    aspect-ratio: 4 / 3;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 6px;
    display: block;
  }
  .pin-dot {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #3f6b4d;
    border: 2px solid #fff;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(20, 20, 18, 0.92);
    display: grid;
    grid-template-columns: 4rem 1fr 4rem;
    grid-template-rows: 1fr auto;
    align-items: center;
    justify-items: center;
    padding: 1rem;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lb-image {
    grid-column: 2;
    grid-row: 1;
    max-width: 100%;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 4px;
  }
  .lb-caption {
    grid-column: 1 / -1;
    grid-row: 2;
    color: #f3f1ec;
    font-size: 0.9rem;
    margin: 0.75rem 0 0;
    text-align: center;
    min-height: 1.2em;
  }
  .lb-close,
  .lb-prev,
  .lb-next {
    background: none;
    border: 0;
    color: #fff;
    cursor: pointer;
    line-height: 1;
  }
  .lb-close {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    font-size: 2rem;
  }
  .lb-prev,
  .lb-next {
    font-size: 3rem;
    grid-row: 1;
    padding: 0 0.5rem;
  }
  .lb-prev {
    grid-column: 1;
  }
  .lb-next {
    grid-column: 3;
  }
</style>

<script>
  type LBPhoto = {
    index: number;
    full: string;
    caption: string | null;
    placed: boolean;
    lng: number | null;
    lat: number | null;
  };

  function initGallery(root: HTMLElement) {
    if (root.dataset.galleryReady) return;
    root.dataset.galleryReady = 'true';
    const dataEl = root.querySelector('.gallery-data');
    if (!dataEl?.textContent) return;
    const photos: LBPhoto[] = JSON.parse(dataEl.textContent);

    const lb = root.querySelector<HTMLElement>('[data-lightbox]')!;
    const img = root.querySelector<HTMLImageElement>('[data-lb-image]')!;
    const caption = root.querySelector<HTMLElement>('[data-lb-caption]')!;
    let current = 0;

    // Locate a map on the same page so opening a placed photo flies to it.
    const mapEl = document.querySelector<HTMLElement>('[data-map]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function show(i: number) {
      current = (i + photos.length) % photos.length;
      const p = photos[current];
      img.src = p.full;
      img.alt = p.caption ?? '';
      caption.textContent = p.caption ?? '';
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
      if (p.placed && p.lng != null && p.lat != null && mapEl && (mapEl as any).__map) {
        const map = (mapEl as any).__map;
        if (reducedMotion) map.jumpTo({ center: [p.lng, p.lat], zoom: 14 });
        else map.flyTo({ center: [p.lng, p.lat], zoom: 14, speed: 0.8 });
      }
    }
    function close() {
      lb.hidden = true;
      document.body.style.overflow = '';
    }

    root.querySelectorAll<HTMLElement>('.gallery-item').forEach((btn) => {
      btn.addEventListener('click', () => show(Number(btn.dataset.index)));
    });
    root.querySelector('[data-lb-close]')!.addEventListener('click', close);
    root.querySelector('[data-lb-prev]')!.addEventListener('click', () => show(current - 1));
    root.querySelector('[data-lb-next]')!.addEventListener('click', () => show(current + 1));
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(current - 1);
      else if (e.key === 'ArrowRight') show(current + 1);
    });

    // Clicking a photo marker on the map opens the matching lightbox entry.
    document.addEventListener('photo-marker-click', (e) => {
      const idx = (e as CustomEvent).detail?.index;
      if (typeof idx === 'number') show(idx);
    });
  }

  const init = () => document.querySelectorAll<HTMLElement>('[data-gallery]').forEach(initGallery);
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>
