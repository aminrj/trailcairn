---
import type { LifetimeStats } from '../lib/stats';

interface Props {
  stats: LifetimeStats;
}
const { stats } = Astro.props;
const fmt = new Intl.DateTimeFormat('en', { month: 'short', year: 'numeric' });

const first = stats.firstDate ? fmt.format(stats.firstDate) : null;
const last = stats.lastDate ? fmt.format(stats.lastDate) : null;
// Collapse to a single label when both ends fall in the same month/year.
const range = first && last ? (first === last ? first : `${first} – ${last}`) : '—';

const cells: { label: string; value: string }[] = [
  { label: 'Hikes', value: String(stats.hikeCount) },
  { label: 'Days out', value: String(stats.totalDays) },
  { label: 'Nights out', value: String(stats.totalNights) },
  { label: 'Distance', value: `${stats.totalDistanceKm} km` },
  { label: 'Ascent', value: `${stats.totalAscentM} m` },
  { label: 'Span', value: range },
];
---

{
  stats.hikeCount > 0 && (
    <dl class="lifetime-band">
      {cells.map((c) => (
        <div>
          <dt>{c.label}</dt>
          <dd>{c.value}</dd>
        </div>
      ))}
    </dl>
  )
}

<style>
  .lifetime-band {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 3rem;
    margin: 2.75rem 0 0;
    padding: 1.5rem 0 1.6rem;
    border-top: 1px solid var(--line, #e4e0d8);
    border-bottom: 1px solid var(--line, #e4e0d8);
  }
  .lifetime-band div {
    margin: 0;
  }
  .lifetime-band dt {
    font-family: var(--font-mono, monospace);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-soft, #5b5b54);
    margin-bottom: 0.4rem;
  }
  .lifetime-band dd {
    margin: 0;
    font-family: var(--font-mono, monospace);
    font-size: 2.1rem;
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--ink, #1a1a17);
  }
</style>
