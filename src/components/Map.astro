---
import type { Feature, LineString } from 'geojson';
import { ENABLED_BASEMAPS, DEFAULT_BASEMAP_ID } from '../lib/map';

export interface MapPhoto {
  lng: number;
  lat: number;
  thumb: string;
  full: string;
  caption?: string;
  index: number;
}

export interface MapHike {
  slug: string;
  title: string;
  date: string;
  distance_km: number | null;
  cover?: string | null;
}

interface Props {
  /** Unique DOM id for this map instance. */
  id: string;
  /** One or more track lines to draw. */
  lines: Feature<LineString>[];
  /** Start pins, [lon, lat], index-aligned with `lines`. null omits a pin (privacy). */
  starts?: ([number, number] | null)[];
  /** Bounds [[minLon,minLat],[maxLon,maxLat]] to fit on load. null → default view (no hikes). */
  bounds: [[number, number], [number, number]] | null;
  /** Optional per-hike metadata for index popups, keyed by line index. */
  hikes?: (MapHike | null)[];
  /** Optional photo markers (per-hike map). */
  photos?: MapPhoto[];
  /** Animate a line-draw reveal (single-track pages). Default false. */
  reveal?: boolean;
  /** Overview mode (index): clustered cairn pins + labels, faint tracks, zoomed-out fit. */
  overview?: boolean;
  /** Initial basemap id (defaults to the per-hike topo). */
  defaultBasemap?: string;
  height?: string;
}

const {
  id,
  lines,
  starts = [],
  bounds,
  hikes = [],
  photos = [],
  reveal = false,
  overview = false,
  defaultBasemap = DEFAULT_BASEMAP_ID,
  height = '60vh',
} = Astro.props;

const config = {
  basemaps: ENABLED_BASEMAPS.map((b) => ({ id: b.id, label: b.label, style: b.style })),
  defaultBasemapId: defaultBasemap,
  lines,
  starts,
  bounds,
  hikes,
  photos,
  reveal,
  overview,
};
---

<div class="maplibre-map" id={id} data-map style={`--map-height:${height}`}>
  <script type="application/json" class="map-config" set:html={JSON.stringify(config)}></script>
  <noscript>
    <p class="map-fallback">An interactive map requires JavaScript.</p>
  </noscript>
</div>

<style>
  .maplibre-map {
    position: relative;
    width: 100%;
    height: var(--map-height, 60vh);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--line, #e4e0d8);
    background: #eef1f0;
  }
  .map-fallback {
    padding: 1rem;
    font-size: 0.9rem;
  }
  /* Photo markers are small thumbnails (SPEC §6). Outer is positioned by
     MapLibre; the inner holds the image so it can animate without fighting the
     marker's translate transform. */
  :global(.photo-marker) {
    width: 36px;
    height: 36px;
    cursor: pointer;
    z-index: 1;
  }
  :global(.photo-marker-img) {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 1px 5px rgba(0, 0, 0, 0.45);
    background-size: cover;
    background-position: center;
    background-color: #cdd3d0;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }
  /* Pop + glow as the replay marker passes this photo (reduced-motion gated by JS). */
  :global(.photo-marker.is-passing) {
    z-index: 5;
  }
  :global(.photo-marker.is-passing .photo-marker-img) {
    transform: scale(1.7);
    box-shadow:
      0 0 0 3px rgba(192, 57, 43, 0.55),
      0 3px 9px rgba(0, 0, 0, 0.5);
  }
  :global(.maplibregl-popup-content) {
    font-family: var(--font-body, sans-serif);
    font-size: 0.85rem;
  }
  /* Basemap switcher control. */
  :global(.basemap-switch) {
    display: flex;
    gap: 2px;
    padding: 3px;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 6px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }
  :global(.basemap-switch button) {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.02em;
    border: 0;
    background: none;
    color: #444;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    cursor: pointer;
  }
  :global(.basemap-switch button[aria-pressed='true']) {
    background: var(--accent, #3f6b4d);
    color: #fff;
  }
</style>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  type BasemapDef = { id: string; label: string; style: string | maplibregl.StyleSpecification };
  type HikeMeta = { slug: string; title: string; date: string; distance_km: number | null };
  type Cfg = {
    basemaps: BasemapDef[];
    defaultBasemapId: string;
    lines: GeoJSON.Feature<GeoJSON.LineString>[];
    starts: ([number, number] | null)[];
    bounds: [[number, number], [number, number]] | null;
    hikes: (HikeMeta | null)[];
    photos: { lng: number; lat: number; thumb: string; full: string; caption?: string; index: number }[];
    reveal: boolean;
    overview: boolean;
  };

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const BASEMAP_KEY = 'trailcairn:basemap';

  // Cairn-on-a-pin icon for the overview map. A teardrop pin with a small
  // stacked-cairn motif. Drawn as SVG, loaded once and re-added per style.
  const PIN_SVG = `<svg xmlns='http://www.w3.org/2000/svg' width='48' height='60' viewBox='0 0 48 60'>
    <path d='M24 2 C12 2 3 11 3 23 C3 38 24 58 24 58 C24 58 45 38 45 23 C45 11 36 2 24 2 Z' fill='#3f6b4d' stroke='#ffffff' stroke-width='2.5'/>
    <ellipse cx='24' cy='29' rx='9' ry='3.1' fill='#ffffff'/>
    <ellipse cx='24' cy='23.5' rx='6.8' ry='2.7' fill='#ffffff'/>
    <ellipse cx='24' cy='18.5' rx='4.8' ry='2.3' fill='#ffffff'/>
    <circle cx='24' cy='14' r='2.5' fill='#ffffff'/>
  </svg>`;
  const pinImg = new Image();
  const pinReady = new Promise<void>((res) => {
    pinImg.onload = () => res();
    pinImg.onerror = () => res();
  });
  pinImg.src = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(PIN_SVG)}`;

  // Small basemap switcher control (terrain / topo / satellite). Unobtrusive
  // segmented buttons; the choice is remembered for the session.
  class BasemapControl {
    _container!: HTMLElement;
    constructor(
      private basemaps: BasemapDef[],
      private currentId: string,
      private onSelect: (id: string) => void,
    ) {}
    onAdd() {
      const c = document.createElement('div');
      c.className = 'maplibregl-ctrl basemap-switch';
      for (const b of this.basemaps) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = b.label;
        btn.setAttribute('aria-pressed', String(b.id === this.currentId));
        btn.addEventListener('click', () => {
          if (b.id === this.currentId) return;
          this.currentId = b.id;
          c.querySelectorAll('button').forEach((x) =>
            x.setAttribute('aria-pressed', String(x.textContent === b.label)),
          );
          this.onSelect(b.id);
        });
        c.appendChild(btn);
      }
      this._container = c;
      return c;
    }
    onRemove() {
      this._container.remove();
    }
  }

  function initMap(el: HTMLElement) {
    if (el.dataset.mapReady) return;
    el.dataset.mapReady = 'true';
    const cfgEl = el.querySelector('.map-config');
    if (!cfgEl?.textContent) return;
    const cfg: Cfg = JSON.parse(cfgEl.textContent);

    const ids = cfg.basemaps.map((b) => b.id);
    const styleFor = (id: string) => cfg.basemaps.find((b) => b.id === id)!.style;
    let stored: string | null = null;
    try {
      stored = sessionStorage.getItem(BASEMAP_KEY);
    } catch {}
    const initialId = stored && ids.includes(stored) ? stored : cfg.defaultBasemapId;

    const fullLines: GeoJSON.FeatureCollection = {
      type: 'FeatureCollection',
      features: cfg.lines.map((line, i) => ({
        ...line,
        properties: { ...line.properties, idx: i, slug: cfg.hikes[i]?.slug },
      })),
    };
    const startFeatures = cfg.starts
      .map((s, i) =>
        s
          ? { type: 'Feature' as const, properties: { idx: i }, geometry: { type: 'Point' as const, coordinates: s } }
          : null,
      )
      .filter((f): f is NonNullable<typeof f> => f !== null);
    // Overview pins carry place/date for labels and slug for filtering.
    const pinFeatures = cfg.starts
      .map((s, i) =>
        s && cfg.hikes[i]
          ? {
              type: 'Feature' as const,
              properties: { idx: i, slug: cfg.hikes[i]!.slug, title: cfg.hikes[i]!.title, date: cfg.hikes[i]!.date },
              geometry: { type: 'Point' as const, coordinates: s },
            }
          : null,
      )
      .filter((f): f is NonNullable<typeof f> => f !== null);

    const mapOptions: maplibregl.MapOptions = {
      container: el,
      style: styleFor(initialId),
      attributionControl: { compact: true },
    };
    if (cfg.bounds) {
      mapOptions.bounds = cfg.bounds;
      // Overview reads as "where I've wandered": breathing room, not a tight fit.
      mapOptions.fitBoundsOptions = cfg.overview
        ? { padding: 80, maxZoom: 8, animate: false }
        : { padding: 48, animate: false };
    } else {
      // No hikes yet: show an empty default view rather than nothing.
      mapOptions.center = [12, 55];
      mapOptions.zoom = 3;
    }
    const map = new maplibregl.Map(mapOptions);
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');
    if (cfg.basemaps.length > 1) {
      map.addControl(
        new BasemapControl(cfg.basemaps, initialId, (id) => {
          try {
            sessionStorage.setItem(BASEMAP_KEY, id);
          } catch {}
          // Full reload so raster↔vector basemaps swap cleanly; overlays are
          // re-added on the resulting style.load.
          map.setStyle(styleFor(id), { diff: false });
        }),
        'top-left',
      );
    }

    // Track + pin sources/layers. Re-added on every style load because
    // setStyle() clears non-basemap sources/layers.
    const addOverlayLayers = () => {
      if (!map.getSource('tracks')) {
        map.addSource('tracks', { type: 'geojson', data: fullLines, lineMetrics: true });
        map.addLayer({
          id: 'tracks-line',
          type: 'line',
          source: 'tracks',
          layout: { 'line-cap': 'round', 'line-join': 'round' },
          // On the overview, tracks are quiet context; pins are the subject.
          paint: cfg.overview
            ? { 'line-color': '#7a5b52', 'line-width': 1.5, 'line-opacity': 0.5 }
            : { 'line-color': '#c0392b', 'line-width': 3.5, 'line-opacity': 0.9 },
        });
      }

      if (cfg.overview) {
        if (pinFeatures.length && !map.getSource('pins')) {
          map.addSource('pins', {
            type: 'geojson',
            data: { type: 'FeatureCollection', features: pinFeatures },
            cluster: true,
            clusterRadius: 46,
            clusterMaxZoom: 9,
          });
          // Cluster bubbles (numbered).
          map.addLayer({
            id: 'pins-clusters',
            type: 'circle',
            source: 'pins',
            filter: ['has', 'point_count'],
            paint: {
              'circle-color': '#3f6b4d',
              'circle-opacity': 0.92,
              'circle-stroke-color': '#fff',
              'circle-stroke-width': 2,
              'circle-radius': ['step', ['get', 'point_count'], 15, 5, 19, 10, 25],
            },
          });
          map.addLayer({
            id: 'pins-count',
            type: 'symbol',
            source: 'pins',
            filter: ['has', 'point_count'],
            layout: { 'text-field': ['get', 'point_count_abbreviated'], 'text-font': ['Noto Sans Bold'], 'text-size': 13 },
            paint: { 'text-color': '#fff' },
          });
          // Individual cairn pins with a collision-aware place/date label.
          map.addLayer({
            id: 'pins-unclustered',
            type: 'symbol',
            source: 'pins',
            filter: ['!', ['has', 'point_count']],
            layout: {
              'icon-image': 'hike-pin',
              'icon-size': 1,
              'icon-anchor': 'bottom',
              'icon-allow-overlap': true,
              'text-field': [
                'format',
                ['get', 'title'],
                { 'font-scale': 1 },
                '\n',
                {},
                ['get', 'date'],
                { 'font-scale': 0.8, 'text-color': '#5b5b54' },
              ],
              'text-font': ['Noto Sans Bold'],
              'text-size': 12,
              'text-anchor': 'top',
              'text-offset': [0, 0.5],
              'text-optional': true, // show the pin even when the label collides
            },
            paint: { 'text-color': '#1a1a17', 'text-halo-color': '#faf8f4', 'text-halo-width': 1.6 },
          });
        }
      } else if (startFeatures.length && !map.getSource('starts')) {
        map.addSource('starts', { type: 'geojson', data: { type: 'FeatureCollection', features: startFeatures } });
        map.addLayer({
          id: 'starts-circle',
          type: 'circle',
          source: 'starts',
          paint: { 'circle-radius': 6, 'circle-color': '#3f6b4d', 'circle-stroke-color': '#fff', 'circle-stroke-width': 2 },
        });
      }
    };

    // One-time: click popups, photo markers, line reveal. Layer click handlers
    // and HTML markers persist across setStyle, so register them once.
    const addInteractions = () => {
      if (cfg.hikes.length) {
        const openPopup = (idx: number, lngLat: maplibregl.LngLatLike) => {
          const hike = cfg.hikes[idx];
          if (!hike) return;
          const dist = hike.distance_km != null ? ` · ${hike.distance_km} km` : '';
          new maplibregl.Popup({ closeButton: false, offset: 14 })
            .setLngLat(lngLat)
            .setHTML(
              `<a href="/hikes/${hike.slug}" style="text-decoration:none;color:inherit">` +
                `<strong>${hike.title}</strong><br><span style="opacity:.7">${hike.date}${dist}</span></a>`,
            )
            .addTo(map);
        };
        // Overview: pins open popups; clusters zoom in. Per-hike: track/start.
        const popupLayers = cfg.overview ? ['pins-unclustered'] : ['tracks-line', 'starts-circle'];
        for (const layer of popupLayers) {
          map.on('click', layer, (e) => openPopup((e.features?.[0]?.properties?.idx as number) ?? 0, e.lngLat));
          map.on('mouseenter', layer, () => (map.getCanvas().style.cursor = 'pointer'));
          map.on('mouseleave', layer, () => (map.getCanvas().style.cursor = ''));
        }
        if (cfg.overview) {
          map.on('click', 'pins-clusters', (e) => {
            const f = e.features?.[0];
            const clusterId = f?.properties?.cluster_id;
            const src = map.getSource('pins') as maplibregl.GeoJSONSource;
            if (clusterId == null || !src) return;
            src.getClusterExpansionZoom(clusterId).then((zoom) => {
              map.easeTo({ center: (f!.geometry as any).coordinates, zoom: zoom + 0.2 });
            });
          });
          map.on('mouseenter', 'pins-clusters', () => (map.getCanvas().style.cursor = 'pointer'));
          map.on('mouseleave', 'pins-clusters', () => (map.getCanvas().style.cursor = ''));
        }
      }

      const photoMarkerEls: { lng: number; lat: number; el: HTMLElement; index: number }[] = [];
      for (const photo of cfg.photos) {
        const node = document.createElement('div');
        node.className = 'photo-marker';
        node.title = photo.caption ?? '';
        const img = document.createElement('div');
        img.className = 'photo-marker-img';
        img.style.backgroundImage = `url("${photo.thumb}")`;
        node.appendChild(img);
        node.addEventListener('click', () => {
          el.dispatchEvent(new CustomEvent('photo-marker-click', { bubbles: true, detail: { index: photo.index } }));
        });
        new maplibregl.Marker({ element: node, anchor: 'center' }).setLngLat([photo.lng, photo.lat]).addTo(map);
        photoMarkerEls.push({ lng: photo.lng, lat: photo.lat, el: node, index: photo.index });
      }
      // Expose for the replay player (pass-by animation).
      (el as any).__photoMarkers = photoMarkerEls;

      if (cfg.reveal && !prefersReducedMotion && cfg.lines.length === 1) {
        const coords = cfg.lines[0].geometry.coordinates;
        const source = map.getSource('tracks') as maplibregl.GeoJSONSource;
        const duration = 900;
        const start = performance.now();
        const step = (now: number) => {
          const t = Math.min(1, (now - start) / duration);
          const count = Math.max(2, Math.floor(t * coords.length));
          source.setData({
            type: 'FeatureCollection',
            features: [{ type: 'Feature', properties: { idx: 0 }, geometry: { type: 'LineString', coordinates: coords.slice(0, count) } }],
          });
          if (t < 1) requestAnimationFrame(step);
          else source.setData(fullLines);
        };
        source.setData({
          type: 'FeatureCollection',
          features: [{ type: 'Feature', properties: { idx: 0 }, geometry: { type: 'LineString', coordinates: coords.slice(0, 2) } }],
        });
        requestAnimationFrame(step);
      }
    };

    let interactionsReady = false;
    // style.load fires on first load and after every setStyle().
    map.on('style.load', async () => {
      if (cfg.overview) {
        await pinReady;
        if (!map.hasImage('hike-pin')) map.addImage('hike-pin', pinImg, { pixelRatio: 2 });
      }
      addOverlayLayers();
      if (!interactionsReady) {
        interactionsReady = true;
        addInteractions();
      }
    });

    // Expose for the page (lightbox fly-to, replay player).
    (el as any).__map = map;

    // Live filter hook (index search): show only the given hike slugs, or all
    // when passed null. Filters both the pins and the faint track lines; the
    // clustered pin source recomputes clusters from the filtered set.
    (el as any).__setHikeFilter = (slugs: Set<string> | null) => {
      const pinsSrc = map.getSource('pins') as maplibregl.GeoJSONSource | undefined;
      const tracksSrc = map.getSource('tracks') as maplibregl.GeoJSONSource | undefined;
      if (pinsSrc) {
        pinsSrc.setData({
          type: 'FeatureCollection',
          features: slugs ? pinFeatures.filter((f) => slugs.has(f.properties.slug)) : pinFeatures,
        });
      }
      if (tracksSrc) {
        tracksSrc.setData({
          type: 'FeatureCollection',
          features: slugs ? fullLines.features.filter((f) => slugs.has((f.properties as any)?.slug)) : fullLines.features,
        });
      }
    };
  }

  const init = () => document.querySelectorAll<HTMLElement>('[data-map]').forEach(initMap);
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>
