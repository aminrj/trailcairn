---
// Pagefind search box (SPEC §3.1). Pagefind builds its index as a postbuild
// step against dist/, so the /pagefind/ assets only exist in production builds.
// We therefore only load them in PROD; in `npm run dev` we show a hint instead
// (avoids 404 noise). Verify search via `npm run build && npm run preview`.
const isProd = import.meta.env.PROD;
---

<div class="search">
  {isProd ? (
    <div id="pagefind-search" data-search></div>
  ) : (
    <p class="search-hint meta">
      Search is generated at build time — run <code>npm run build</code> then{' '}
      <code>npm run preview</code> to try it.
    </p>
  )}
</div>

{
  isProd && (
    <Fragment>
      <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
      <script is:inline src="/pagefind/pagefind-ui.js"></script>
      <script is:inline>
        window.addEventListener('load', () => {
          if (window.PagefindUI) {
            new window.PagefindUI({
              element: '#pagefind-search',
              showSubResults: true,
              showImages: false,
              resetStyles: false,
            });
          }
        });
      </script>
    </Fragment>
  )
}

<style>
  .search {
    margin: 1.5rem 0 0;
  }
  .search-hint {
    margin: 0.5rem 0 0;
  }
  :global(.pagefind-ui__search-input) {
    font-family: var(--font-body, sans-serif);
  }
</style>
